<!DOCTYPE html>
<html lang=<%= config.language === 'zh' ? 'zh-CN' : config.language %>>
<%- partial('_partial/head') %>
<body style="margin:0; padding:0; width:100%; min-height:100vh; background:#f5f5f5;">

<!-- 移动端导航按钮 -->
<div class="site-nav-toggle" id="site-nav-toggle" style="display:none;">
    <button>
        <span class="btn-bar"></span>
        <span class="btn-bar"></span>
        <span class="btn-bar"></span>
    </button>
</div>

<!-- 顶部标语（移动端显示） -->
<div class="index-about" style="display:none;">
    <i> <%= config.subtitle %> </i>
</div>

<!-- 主容器：使用 Flex 布局实现全屏 -->
<div class="index-container" style="display:flex; width:100%; min-height:100vh; margin:0; padding:0;">
    
    <% if(!is_current('/404')){%>
    <!-- 左侧导航：固定宽度 280px，高度100% -->
    <div class="index-left" style="width:280px; position:sticky; top:0; height:100vh; overflow-y:auto; background:#fff; box-shadow:2px 0 10px rgba(0,0,0,0.05);">
        <%- partial('_partial/nav', null, {cache: false}) %>
        <!-- 移动端标语（在导航内显示） -->
        <div class="index-about-mobile" style="padding:20px; text-align:center; color:#666; border-top:1px solid #eee;">
            <i> <%= config.subtitle %> </i>
        </div>
    </div>
    <% } %>
    
    <!-- 右侧内容区域：flex:1 自动占满剩余宽度 -->
    <div class="index-middle" style="flex:1; padding:40px; background:#f5f5f5; overflow-y:auto;">
        <!-- Main Content -->
        <div style="width:100%;">
            <%- body %>
        </div>
    </div>
    
</div>

<!-- 页脚 -->
<%- partial('_partial/footer', null, {cache: false}) %>

</body>

<script>
    // We expose some of the variables needed by the front end
    window.hexo_search_path = "<%- config.search ? config.search.path : ""%>"
    window.hexo_root = "<%- config.root %>"
    window.isPost = <%- is_post() %>
</script>
<script src="https://cdn.bootcss.com/jquery/3.3.1/jquery.min.js"></script>
<%- js('js/index.js') %>
<script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

<%if( (page.comments) && config.comment && config.comment.type === 'gitment'){%>
<%- js('js/gitment.js') %>
<script>
    var gitment = new Gitment({
        id: '<%- page.title %>',
        owner: '<%- config.comment.owner %>',
        repo: '<%- config.comment.repo %>',
        oauth: {
            client_id: '<%- config.comment.id %>',
            client_secret: '<%- config.comment.secret %>',
        },
    })
    gitment.render('comment-container')
</script>
<%}%>

<%if( (page.comments) && config.comment && config.comment.type === 'disqus'){%>
    <script>
        if( '<%- config.comment.url %>' || '<%- config.comment.identifier %>')
        var disqus_config = function () {
            this.page.url = '<%- config.comment.url %>';
            this.page.identifier = '<%- config.comment.identifier %>';
        };

        (function() {
            var d = document, s = d.createElement('script');
            s.src = '<%- config.comment.script %>';
            s.setAttribute('data-timestamp', +new Date());
            (d.head || d.body).appendChild(s);
        })();
    </script>
<% } %>

<%if( (page.comments) && config.comment && config.comment.type === 'giscus'){%>
    <%- config.comment.script %>
<% } %>

<%if( (page.comments) && config.comment && config.comment.type === 'livere'){%>
    <div id="lv-container" style="margin-top:40px;"></div>
    <script type="text/javascript">
       (function() {
           if (typeof LivereTower === 'function') { return; }

           var j, d = document.getElementById('lv-container');

           d.setAttribute('data-id','<%- config.comment.livere_id %>');
           d.setAttribute('data-uid' , '<%- config.comment.livere_uid %>');

           j = document.createElement('script');
           j.src = 'https://cdn-city.livere.com/js/embed.dist.js';
           j.async = true;

           d.appendChild(j);
       })();
    </script>
    <noscript>为正常使用来必力评论功能请激活JavaScript</noscript>
<% } %>

<!-- 针对移动端的响应式样式 -->
<style>
@media (max-width: 768px) {
    .index-container {
        flex-direction: column !important;
    }
    .index-left {
        width: 100% !important;
        height: auto !important;
        position: relative !important;
        box-shadow: none !important;
        border-bottom: 1px solid #eee;
    }
    .index-middle {
        padding: 20px !important;
    }
    .site-nav-toggle {
        display: block !important;
        position: fixed;
        top: 15px;
        right: 15px;
        z-index: 1000;
    }
    .index-about {
        display: block !important;
        text-align: center;
        padding: 15px;
        background: #fff;
        border-bottom: 1px solid #eee;
    }
}
</style>

</html>